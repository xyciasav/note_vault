{
  "name": "vault-notes",
  "version": "2.0.12",
  "description": "Local-first Windows notes and file vault with tags, search, and backups.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "start": "electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "build:main": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-placeholder": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@vitejs/plugin-react": "latest",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "12.11.1",
    "clsx": "latest",
    "electron-is-dev": "latest",
    "lucide-react": "latest",
    "pdf-parse": "^2.4.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/uuid": "latest",
    "concurrently": "latest",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "build": {
    "appId": "com.local.vaultnotes",
    "productName": "Note Vault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
